{
  "name": "feishu-message-test",
  "version": "0.1.0",
  "description": "飞书消息 bot：扫码创建应用，通过 Claude Code / Codex 处理消息",
  "type": "module",
  "bin": {
    "feishu-message-test": "./bin/feishu-message-test.mjs"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts run",
    "start": "tsx src/cli/index.ts run",
    "build": "tsup",
    "start:dist": "node bin/feishu-message-test.mjs run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@larksuite/channel": "^0.2.0",
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "graceful-fs": "^4.2.11",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/graceful-fs": "^4.1.9",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "license": "MIT"
}
